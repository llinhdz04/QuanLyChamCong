@{
    ViewData["Title"] = "Bảng lương cá nhân";
    int     month      = ViewBag.Month      ?? DateTime.Today.Month;
    int     year       = ViewBag.Year       ?? DateTime.Today.Year;
    decimal totalHours = ViewBag.TotalHours ?? 0m;
    decimal salary     = ViewBag.Salary     ?? 0m;
    decimal prevSalary = ViewBag.PrevSalary ?? 0m;
    decimal prevHours  = ViewBag.PrevHours  ?? 0m;
    int     workDays   = ViewBag.WorkDays   ?? 0;
    var     records    = ViewBag.Records    as List<QuanLyChamCong.Models.Attendance> ?? new();

    var history = ViewBag.SalaryHistory as IEnumerable<dynamic>;
    decimal diff    = salary - prevSalary;
    bool    isUp    = diff >= 0;
    string  diffStr = (isUp ? "+" : "") + diff.ToString("N0") + "₫";
}

{{* ── Month/Year filter ────────────────────────────────── *}}
<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex align-items-center gap-2 flex-wrap">
            <span style="font-weight:600;font-size:.85rem">📅 Xem tháng:</span>
            <select name="month" class="form-select form-select-sm" style="width:auto">
                @for (int m = 1; m <= 12; m++)
                {
                    if (m == month) { <option value="@m" selected>Tháng @m</option> }
                    else            { <option value="@m">Tháng @m</option> }
                }
            </select>
            <select name="year" class="form-select form-select-sm" style="width:auto">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                {
                    if (y == year) { <option value="@y" selected>@y</option> }
                    else           { <option value="@y">@y</option> }
                }
            </select>
            <button type="submit" class="btn btn-primary btn-sm">Xem</button>
        </form>
    </div>
</div>

{{* ── Summary cards ────────────────────────────────────── *}}
<div class="stats-grid mb-4" style="grid-template-columns:repeat(4,1fr)">
    <div class="stat-card">
        <div class="stat-icon blue">📅</div>
        <div class="stat-info">
            <div class="stat-value">@workDays</div>
            <div class="stat-label">Ngày đi làm</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">⏱</div>
        <div class="stat-info">
            <div class="stat-value">@totalHours.ToString("0.0")h</div>
            <div class="stat-label">Tổng giờ làm</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">💰</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:1.05rem">@salary.ToString("N0")₫</div>
            <div class="stat-label">Lương tháng @month</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon @(isUp ? "green" : "red")">@(isUp ? "📈" : "📉")</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:1rem;color:var(@(isUp ? "--success" : "--danger"))">
                @diffStr
            </div>
            <div class="stat-label">So tháng trước</div>
        </div>
    </div>
</div>

<div class="row g-4">
    {{* ── Bảng chi tiết ────────────────────────────────────── *}}
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header-bar">
                <h5>📋 Chi tiết công tháng @month/@year</h5>
                <span class="text-muted" style="font-size:.8rem">Đơn giá 30,000₫/giờ</span>
            </div>
            <div class="card-body p-0">
                @if (!records.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <p>Không có dữ liệu tháng @month/@year</p>
                    </div>
                }
                else
                {
                    <table class="table-modern w-100">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Vào</th>
                                <th>Ra</th>
                                <th>Giờ</th>
                                <th>Lương ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ decimal pageTotal = 0m; }
                            @foreach (var a in records)
                            {
                                pageTotal += a.TotalHours ?? 0m;
                                <tr>
                                    <td class="fw-bold">@a.Date.ToString("dd/MM")</td>
                                    <td>
                                        @if (a.CheckInTime.HasValue)
                                        { <span class="badge-pill success">@a.CheckInTime.Value.ToString("HH:mm")</span> }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td>
                                        @if (a.CheckOutTime.HasValue)
                                        { <span class="badge-pill danger">@a.CheckOutTime.Value.ToString("HH:mm")</span> }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td>@((a.TotalHours ?? 0m).ToString("0.0"))h</td>
                                    <td style="color:var(--success)">@(((a.TotalHours ?? 0m) * 30000m).ToString("N0"))₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:#f8fafc;font-weight:700">
                                <td colspan="3" class="text-end px-3 py-2">Tổng:</td>
                                <td>@totalHours.ToString("0.0")h</td>
                                <td style="color:var(--success)">@salary.ToString("N0")₫</td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    </div>

    {{* ── Lịch sử 12 tháng ──────────────────────────────────── *}}
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header-bar">
                <h5>📊 Lịch sử lương 12 tháng</h5>
            </div>
            <div class="card-body p-0">
                <table class="table-modern w-100">
                    <thead>
                        <tr>
                            <th>Tháng</th>
                            <th>Giờ</th>
                            <th>Lương</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (history != null)
                        {
                            @foreach (var h in history)
                            {
                                bool isCurrent = h.Label == $"T{month}";
                                <tr @(isCurrent ? "style=background:rgba(99,102,241,.06);font-weight:700" : "")>
                                    <td>
                                        @h.Label
                                        @if (isCurrent)
                                        { <span class="badge-pill info ms-1" style="font-size:.65rem">hiện tại</span> }
                                    </td>
                                    <td>@((decimal)h.Hours).ToString("0.0")h</td>
                                    <td style="color:var(--success)">@((decimal)h.Salary).ToString("N0")₫</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        {{* Tóm tắt so sánh *}}
        <div class="card mt-3">
            <div class="card-body p-3">
                <div style="font-size:.85rem;font-weight:700;margin-bottom:12px">📌 So sánh tháng trước</div>
                <div class="d-flex justify-content-between mb-2" style="font-size:.83rem">
                    <span class="text-muted">Tháng @(month == 1 ? 12 : month - 1)</span>
                    <span>@prevHours.ToString("0.0")h · @prevSalary.ToString("N0")₫</span>
                </div>
                <div class="d-flex justify-content-between mb-2" style="font-size:.83rem">
                    <span class="text-muted">Tháng @month (hiện tại)</span>
                    <span class="fw-bold">@totalHours.ToString("0.0")h · @salary.ToString("N0")₫</span>
                </div>
                <div class="d-flex justify-content-between" style="font-size:.83rem">
                    <span class="text-muted">Chênh lệch</span>
                    <span style="color:var(@(isUp ? "--success" : "--danger"));font-weight:700">@diffStr</span>
                </div>
            </div>
        </div>
    </div>
</div>
