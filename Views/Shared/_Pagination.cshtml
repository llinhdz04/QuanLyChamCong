@* Views/Shared/_Pagination.cshtml
   Usage: <partial name="_Pagination" model='new PaginationModel { ... }' />
*@
@model QuanLyChamCong.ViewModels.PaginationModel

@if (Model.TotalPages > 1)
{
    var baseUrl = Model.BaseUrl;

    string PageUrl(int p) {
        var qs = new System.Collections.Generic.Dictionary<string, string>
        {
            ["page"] = p.ToString()
        };
        if (!string.IsNullOrEmpty(Model.Search))    qs["search"]       = Model.Search;
        if (!string.IsNullOrEmpty(Model.SortBy))    qs["sortBy"]       = Model.SortBy;
        if (!string.IsNullOrEmpty(Model.SortDir))   qs["sortDir"]      = Model.SortDir;
        if (!string.IsNullOrEmpty(Model.Extra1Key)) qs[Model.Extra1Key] = Model.Extra1Val ?? "";
        if (!string.IsNullOrEmpty(Model.Extra2Key)) qs[Model.Extra2Key] = Model.Extra2Val ?? "";
        if (!string.IsNullOrEmpty(Model.Extra3Key)) qs[Model.Extra3Key] = Model.Extra3Val ?? "";
        return baseUrl + "?" + string.Join("&", qs.Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value)}"));
    }

    int from = Math.Max(1, Model.CurrentPage - 2);
    int to   = Math.Min(Model.TotalPages, from + 4);
    from     = Math.Max(1, to - 4);

    <div class="d-flex justify-content-between align-items-center px-3 py-2 mt-1"
         style="border-top:1px solid #eee;font-size:.82rem">

        <span class="text-muted">
            Trang <strong>@Model.CurrentPage</strong> / @Model.TotalPages
            &nbsp;·&nbsp; <strong>@Model.Total</strong> kết quả
        </span>

        <nav>
            <ul class="pagination pagination-sm mb-0 gap-1">

                {{* Prev *}}
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@(Model.CurrentPage > 1 ? PageUrl(Model.CurrentPage - 1) : "#")">‹</a>
                </li>

                @if (from > 1)
                {
                    <li class="page-item"><a class="page-link" href="@PageUrl(1)">1</a></li>
                    if (from > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                }

                @for (int i = from; i <= to; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@PageUrl(i)">@i</a>
                    </li>
                }

                @if (to < Model.TotalPages)
                {
                    if (to < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                    <li class="page-item"><a class="page-link" href="@PageUrl(Model.TotalPages)">@Model.TotalPages</a></li>
                }

                {{* Next *}}
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@(Model.CurrentPage < Model.TotalPages ? PageUrl(Model.CurrentPage + 1) : "#")">›</a>
                </li>

            </ul>
        </nav>
    </div>
}
