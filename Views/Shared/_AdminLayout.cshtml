@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var userId   = HttpContextAccessor.HttpContext?.Session.GetString("UserId");
    var fullName = HttpContextAccessor.HttpContext?.Session.GetString("FullName");
    var userName = HttpContextAccessor.HttpContext?.Session.GetString("UserName");
    var display  = !string.IsNullOrEmpty(fullName) ? fullName : userName;
    var initial  = display?.Length > 0 ? display[0].ToString().ToUpper() : "A";
    var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString();
    var action   = ViewContext.RouteData.Values["action"]?.ToString();

    if (string.IsNullOrEmpty(userId))
    {
        HttpContextAccessor.HttpContext!.Response.Redirect("/Account/Login");
        return;
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="dashboard">
    <aside class="sidebar">
        <div class="logo">
            <div class="logo-icon">⚙</div>
            <span>Admin Panel</span>
        </div>
        <ul class="menu">
            <li class="menu-section">Tổng quan</li>
            <li>
                <a asp-controller="Admin" asp-action="Index"
                   class="@(ctrl=="Admin"&&action=="Index"?"active":"")">
                    <span class="menu-icon">📊</span>Dashboard
                </a>
            </li>
            <li class="menu-section">Nhân sự</li>
            <li>
                <a asp-controller="Admin" asp-action="Users"
                   class="@(action is "Users" or "CreateUser" or "EditUser" or "UserHours"?"active":"")">
                    <span class="menu-icon">👥</span>Nhân viên
                </a>
            </li>
            <li>
                <a asp-controller="Admin" asp-action="Schedules"
                   class="@(action=="Schedules"?"active":"")">
                    <span class="menu-icon">📅</span>Lịch làm việc
                </a>
            </li>
            <li>
                <a asp-controller="LeaveRequest" asp-action="All"
                   class="@(ctrl=="LeaveRequest"?"active":"")">
                    <span class="menu-icon">📋</span>Đơn nghỉ phép
                </a>
            </li>
            <li class="menu-section">Thống kê</li>
            <li>
                <a asp-controller="Admin" asp-action="Report"
                   class="@(action=="Report"?"active":"")">
                    <span class="menu-icon">📈</span>Báo cáo lương
                </a>
            </li>
            <li class="menu-section">Khác</li>
            <li>
                <a asp-controller="Home" asp-action="Index">
                    <span class="menu-icon">🏠</span>Về trang nhân viên
                </a>
            </li>
        </ul>
        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout">
                <span class="menu-icon">🚪</span>Đăng xuất
            </a>
        </div>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <div class="topbar-left">
                <span class="topbar-title">@(ViewData["Title"] ?? "Admin")</span>
                <span class="topbar-sub">@DateTime.Now.ToString("dddd, dd/MM/yyyy")</span>
            </div>
            <div class="topbar-right">
                <div>
                    <div class="topbar-user">@display</div>
                    <div class="topbar-role">Quản trị viên</div>
                </div>
                <div class="topbar-avatar">@initial</div>
            </div>
        </div>
        <div class="content-area">
            @RenderBody()
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
