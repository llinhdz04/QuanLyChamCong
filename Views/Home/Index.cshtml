@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var role = Context.Session.GetString("Role");
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue">⏱</div>
        <div class="stat-info">
            <div class="stat-value">@Model.TodayHours.ToString("0.0")h</div>
            <div class="stat-label">Giờ làm hôm nay</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">📅</div>
        <div class="stat-info">
            <div class="stat-value">@Model.MonthlyHours.ToString("0.0")h</div>
            <div class="stat-label">Tổng giờ tháng này</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">🗓</div>
        <div class="stat-info">
            <div class="stat-value">@Model.WorkDaysThisMonth</div>
            <div class="stat-label">Ngày đi làm tháng này</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">📋</div>
        <div class="stat-info">
            <div class="stat-value">@Model.PendingLeaves</div>
            <div class="stat-label">Đơn nghỉ chờ duyệt</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <!-- Trạng thái hôm nay -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header-bar">
                <h5>📍 Trạng thái hôm nay</h5>
                @if (Model.HasCheckedOut)
                {
                    <span class="badge-pill success">Hoàn thành</span>
                }
                else if (Model.HasCheckedIn)
                {
                    <span class="badge-pill warning">Đang làm</span>
                }
                else
                {
                    <span class="badge-pill gray">Chưa check-in</span>
                }
            </div>
            <div class="card-body d-flex flex-column gap-3">
                <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background:#f8fafc">
                    <div>
                        <div style="font-size:.72rem;color:var(--muted);font-weight:700;text-transform:uppercase">Giờ vào</div>
                        <div style="font-size:1.4rem;font-weight:800;color:var(--success)">
                            @(Model.CheckInTime.HasValue ? Model.CheckInTime.Value.ToString("HH:mm") : "--:--")
                        </div>
                    </div>
                    <span style="font-size:1.6rem">🟢</span>
                </div>
                <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background:#f8fafc">
                    <div>
                        <div style="font-size:.72rem;color:var(--muted);font-weight:700;text-transform:uppercase">Giờ ra</div>
                        <div style="font-size:1.4rem;font-weight:800;color:var(--danger)">
                            @(Model.CheckOutTime.HasValue ? Model.CheckOutTime.Value.ToString("HH:mm") : "--:--")
                        </div>
                    </div>
                    <span style="font-size:1.6rem">🔴</span>
                </div>
                <a asp-controller="Attendance" asp-action="Index"
                   class="btn btn-primary w-100 mt-auto">
                    ⏱ Đi chấm công
                </a>
            </div>
        </div>
    </div>

    <!-- Truy cập nhanh -->
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header-bar">
                <h5>⚡ Truy cập nhanh</h5>
            </div>
            <div class="card-body">
                <div class="quick-grid" style="grid-template-columns:repeat(2,1fr)">
                    <a asp-controller="Attendance" asp-action="History" class="quick-card text-decoration-none">
                        <div class="qc-icon" style="background:rgba(16,185,129,.1)">📊</div>
                        <div>
                            <h5>Lịch sử chấm công</h5>
                            <p>Xem toàn bộ lịch sử</p>
                        </div>
                    </a>
                    <a asp-controller="LeaveRequest" asp-action="Create" class="quick-card text-decoration-none">
                        <div class="qc-icon" style="background:rgba(245,158,11,.1)">📝</div>
                        <div>
                            <h5>Xin nghỉ phép</h5>
                            <p>Tạo đơn nghỉ mới</p>
                        </div>
                    </a>
                    <a asp-controller="LeaveRequest" asp-action="Index" class="quick-card text-decoration-none">
                        <div class="qc-icon" style="background:rgba(99,102,241,.1)">📋</div>
                        <div>
                            <h5>Đơn của tôi</h5>
                            <p>Theo dõi trạng thái đơn</p>
                        </div>
                    </a>
                    <a asp-controller="Schedule" asp-action="Index" class="quick-card text-decoration-none">
                        <div class="qc-icon" style="background:rgba(59,130,246,.1)">📅</div>
                        <div>
                            <h5>Đăng ký ca làm</h5>
                            <p>Quản lý lịch làm việc</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (role == "Admin")
{
    <div class="card">
        <div class="card-header-bar">
            <h5>🔧 Công cụ quản trị</h5>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-sm">Vào Admin Panel</a>
        </div>
        <div class="card-body">
            <div class="quick-grid" style="grid-template-columns:repeat(4,1fr)">
                <a asp-controller="Admin" asp-action="Users" class="quick-card text-decoration-none">
                    <div class="qc-icon" style="background:rgba(99,102,241,.1)">👥</div>
                    <div><h5>Nhân viên</h5><p>Quản lý danh sách</p></div>
                </a>
                <a asp-controller="LeaveRequest" asp-action="All" class="quick-card text-decoration-none">
                    <div class="qc-icon" style="background:rgba(245,158,11,.1)">✅</div>
                    <div><h5>Duyệt nghỉ phép</h5><p>Xử lý đơn chờ duyệt</p></div>
                </a>
                <a asp-controller="Admin" asp-action="Schedules" class="quick-card text-decoration-none">
                    <div class="qc-icon" style="background:rgba(16,185,129,.1)">📅</div>
                    <div><h5>Lịch làm việc</h5><p>Duyệt lịch đăng ký</p></div>
                </a>
                <a asp-controller="Admin" asp-action="Report" class="quick-card text-decoration-none">
                    <div class="qc-icon" style="background:rgba(239,68,68,.1)">📈</div>
                    <div><h5>Báo cáo lương</h5><p>Thống kê tổng hợp</p></div>
                </a>
            </div>
        </div>
    </div>
}
