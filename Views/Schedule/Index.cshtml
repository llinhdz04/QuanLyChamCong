@model List<WorkSchedule>
@{
    ViewData["Title"] = "Lịch làm việc";
}

<div class="row g-3">
    <!-- Form đăng ký -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header-bar">
                <h5>📅 Đăng ký ca làm</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Schedule" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Ngày làm việc</label>
                        <input type="date" name="WorkDate" class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ca làm việc</label>
                        <select name="Shift" class="form-select" required>
                            <option value="">-- Chọn ca --</option>
                            <option value="Ca sáng (6:00 - 14:00)">🌅 Ca sáng (6:00 - 14:00)</option>
                            <option value="Ca chiều (14:00 - 22:00)">🌇 Ca chiều (14:00 - 22:00)</option>
                            <option value="Ca tối (22:00 - 6:00)">🌙 Ca tối (22:00 - 6:00)</option>
                            <option value="Hành chính (8:00 - 17:00)">🏢 Hành chính (8:00 - 17:00)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">📤 Gửi đăng ký</button>
                </form>

                @if (TempData["Success"] != null)
                {
                    <div class="mt-3 p-2 rounded-3 text-center"
                         style="background:rgba(16,185,129,.1);color:var(--success);font-size:.85rem;font-weight:600">
                        ✅ @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="mt-3 p-2 rounded-3 text-center"
                         style="background:rgba(239,68,68,.1);color:var(--danger);font-size:.85rem;font-weight:600">
                        ⚠ @TempData["Error"]
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body py-3">
                <div style="font-size:.8rem;font-weight:600;color:var(--muted);margin-bottom:8px">Chú thích</div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge-pill warning">⏳</span>
                    <span style="font-size:.82rem">Chờ Admin duyệt</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge-pill success">✅</span>
                    <span style="font-size:.82rem">Đã được duyệt</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách đã đăng ký -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header-bar">
                <h5>📋 Lịch đã đăng ký</h5>
                <span class="text-muted" style="font-size:.8rem">@(Model?.Count ?? 0) lịch</span>
            </div>
            <div class="card-body p-0">
                @if (Model == null || !Model.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📅</div>
                        <p>Bạn chưa đăng ký ca làm nào</p>
                    </div>
                }
                else
                {
                    <table class="table-modern w-100">
                        <thead>
                            <tr>
                                <th>Ngày làm</th>
                                <th>Ca làm</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.OrderByDescending(x => x.WorkDate))
                            {
                                <tr>
                                    <td class="fw-bold">@s.WorkDate.ToString("dd/MM/yyyy")</td>
                                    <td>@(s.Shift ?? "—")</td>
                                    <td>
                                        @if (s.IsApproved)
                                        {
                                            <span class="badge-pill success">✅ Đã duyệt</span>
                                        }
                                        else
                                        {
                                            <span class="badge-pill warning">⏳ Chờ duyệt</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
