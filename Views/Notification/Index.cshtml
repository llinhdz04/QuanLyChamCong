@{
    ViewData["Title"] = "Thông báo";
    var leaves = ViewBag.Leaves as List<QuanLyChamCong.Models.LeaveRequest> ?? new();
    var schedules = ViewBag.Schedules as List<QuanLyChamCong.Models.WorkSchedule> ?? new();
    int totalUnread = ViewBag.TotalUnread ?? 0;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <h4 class="mb-0">🔔 Thông báo</h4>
    @if (totalUnread > 0)
    {
        <span class="badge-pill danger">@totalUnread mới</span>
    }
</div>

<div class="row g-4">
    @* - Đơn nghỉ phép - *@
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header-bar">
                <h5>📋 Kết quả đơn nghỉ phép</h5>
                <span class="text-muted" style="font-size:.8rem">@leaves.Count thông báo</span>
            </div>
            <div class="card-body p-0">
                @if (!leaves.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <p>Chưa có thông báo nào</p>
                    </div>
                }
                else
                {
                    @foreach (var l in leaves)
                    {
                        bool isNew = l.Status != "Pending" && l.ApprovedDate >= DateTime.Today.AddDays(-7);
                        string borderColor = l.Status switch
                        {
                            "Approved" => "var(--success)",
                            "Rejected" => "var(--danger)",
                            _ => "var(--warning)"
                        };
                        <div class="notif-item @(isNew ? "notif-new" : "")"
                             style="border-left:3px solid @borderColor">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="notif-title">
                                        @switch (l.Status)
                                        {
                                            case "Approved":
                                                <span>✅ Đơn nghỉ phép đã được <strong>duyệt</strong></span>
                                                break;
                                            case "Rejected":
                                                <span>❌ Đơn nghỉ phép bị <strong>từ chối</strong></span>
                                                break;
                                            default:
                                                <span>⏳ Đơn nghỉ phép đang <strong>chờ duyệt</strong></span>
                                                break;
                                        }
                                    </div>
                                    <div class="notif-meta">
                                        @(l.LeaveType ?? "Nghỉ phép") &nbsp;·&nbsp;
                                        @l.StartDate.ToString("dd/MM/yyyy") – @l.EndDate.ToString("dd/MM/yyyy")
                                        (@((l.EndDate - l.StartDate).Days + 1) ngày)
                                    </div>
                                    @if (l.Status != "Pending" && l.ApprovedBy != null)
                                    {
                                        <div class="notif-meta">
                                            Xử lý bởi: <strong>@l.ApprovedBy</strong>
                                            · @(l.ApprovedDate?.ToString("dd/MM/yyyy HH:mm"))
                                        </div>
                                    }
                                </div>
                                <div class="d-flex flex-column align-items-end gap-1">
                                    @switch (l.Status)
                                    {
                                        case "Approved":
                                            <span class="badge-pill success">Đã duyệt</span>
                                            break;
                                        case "Rejected":

                                            <span class="badge-pill danger">Từ chối</span>
                                            break;
                                        default:

                                            <span class="badge-pill warning">Chờ duyệt</span>
                                            break;
                                    }
                                    @if (isNew)
                                    {
                                        <span class="badge-pill red" style="font-size:.62rem">MỚI</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @* - Lịch làm được duyệt - *@
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header-bar">
                <h5>📅 Lịch làm được duyệt</h5>
                <span class="text-muted" style="font-size:.8rem">@schedules.Count mục</span>
            </div>
            <div class="card-body p-0">
                @if (!schedules.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📅</div>
                        <p>Chưa có lịch nào được duyệt</p>
                    </div>
                }
                else
                {
                    @foreach (var s in schedules)
                    {
                        bool isNew = s.WorkDate >= DateTime.Today.AddDays(-7);
                        <div class="notif-item @(isNew ? "notif-new" : "")"
                             style="border-left:3px solid var(--success)">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="notif-title">✅ Lịch làm đã được <strong>duyệt</strong></div>
                                    <div class="notif-meta">
                                        📅 @s.WorkDate.ToString("dd/MM/yyyy") &nbsp;·&nbsp; @(s.Shift ?? "—")
                                    </div>
                                </div>
                                @if (isNew)
                                {
                                    <span class="badge-pill red" style="font-size:.62rem">MỚI</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        @* Quick actions *@
        <div class="card mt-3">
            <div class="card-body p-3">
                <div style="font-size:.82rem;font-weight:700;margin-bottom:10px;color:var(--muted)">Thao tác nhanh</div>
                <div class="d-flex flex-column gap-2">
                    <a asp-controller="LeaveRequest" asp-action="Create" class="btn btn-ghost btn-sm">
                        📝 Tạo đơn nghỉ phép
                    </a>
                    <a asp-controller="Schedule" asp-action="Index" class="btn btn-ghost btn-sm">
                        📅 Đăng ký lịch làm
                    </a>
                    <a asp-controller="LeaveRequest" asp-action="Index" class="btn btn-ghost btn-sm">
                        📋 Xem tất cả đơn của tôi
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .notif-item {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        transition: background .15s;
    }

        .notif-item:hover {
            background: #f8fafc;
        }

        .notif-item:last-child {
            border-bottom: none;
        }

        .notif-item.notif-new {
            background: rgba(99,102,241,.04);
        }

    .notif-title {
        font-size: .86rem;
        margin-bottom: 3px;
    }

    .notif-meta {
        font-size: .76rem;
        color: var(--muted);
    }
</style>
