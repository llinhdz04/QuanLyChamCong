@model List<WorkSchedule>
@{
    ViewData["Title"] = "Lịch làm việc";
    Layout = "_AdminLayout";

    string search       = ViewBag.Search       ?? "";
    string filterStatus = ViewBag.FilterStatus  ?? "all";
    string sortBy       = ViewBag.SortBy        ?? "workdate";
    string sortDir      = ViewBag.SortDir       ?? "desc";
    int    page         = ViewBag.Page          ?? 1;
    int    totalPages   = ViewBag.TotalPages    ?? 1;
    int    total        = ViewBag.Total         ?? 0;
    int    pendingCount  = ViewBag.PendingCount  ?? 0;
    int    approvedCount = ViewBag.ApprovedCount ?? 0;

    string SortUrl(string col) {
        string dir = (sortBy == col && sortDir == "asc") ? "desc" : "asc";
        return $"?search={Uri.EscapeDataString(search)}&filterStatus={filterStatus}&sortBy={col}&sortDir={dir}&page=1";
    }
    string SortIcon(string col) => sortBy == col ? (sortDir == "asc" ? "↑" : "↓") : "⇅";
    string TabUrl(string status) => $"?search={Uri.EscapeDataString(search)}&filterStatus={status}&sortBy={sortBy}&sortDir={sortDir}&page=1";
}

@* ── Search + Filter bar ──────────────────────────────── *@
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <input type="text" name="search" value="@search"
                   class="form-control" style="max-width:280px"
                   placeholder="🔍  Tìm nhân viên, ca làm..." />
            <input type="hidden" name="filterStatus" value="@filterStatus" />
            <input type="hidden" name="sortBy"       value="@sortBy" />
            <input type="hidden" name="sortDir"      value="@sortDir" />
            <input type="hidden" name="page"         value="1" />
            <button type="submit" class="btn btn-primary">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a href="?filterStatus=@filterStatus&page=1" class="btn btn-ghost">✕ Xoá lọc</a>
            }
        </form>
    </div>
</div>

@* ── Status tabs ──────────────────────────────────────── *@
<div class="d-flex gap-2 mb-3">
    <a href="@TabUrl("all")"
       class="btn btn-sm @(filterStatus=="all"?"btn-primary":"btn-ghost")">
        Tất cả <span class="badge-pill gray ms-1">@(pendingCount + approvedCount)</span>
    </a>
    <a href="@TabUrl("pending")"
       class="btn btn-sm @(filterStatus=="pending"?"btn-primary":"btn-ghost")">
        Chờ duyệt <span class="badge-pill warning ms-1">@pendingCount</span>
    </a>
    <a href="@TabUrl("approved")"
       class="btn btn-sm @(filterStatus=="approved"?"btn-primary":"btn-ghost")">
        Đã duyệt <span class="badge-pill success ms-1">@approvedCount</span>
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        ✅ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header-bar">
        <h5>📅 Danh sách lịch làm</h5>
        <span class="text-muted" style="font-size:.8rem">@total kết quả</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📅</div>
                <p>@(string.IsNullOrEmpty(search) ? "Chưa có lịch làm nào" : $"Không tìm thấy \"{search}\"")</p>
            </div>
        }
        else
        {
            <table class="table-modern w-100">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>
                            <a href="@SortUrl("userid")" class="sort-header">
                                Nhân viên <span class="sort-icon">@SortIcon("userid")</span>
                            </a>
                        </th>
                        <th>
                            <a href="@SortUrl("workdate")" class="sort-header">
                                Ngày làm <span class="sort-icon">@SortIcon("workdate")</span>
                            </a>
                        </th>
                        <th>
                            <a href="@SortUrl("shift")" class="sort-header">
                                Ca làm <span class="sort-icon">@SortIcon("shift")</span>
                            </a>
                        </th>
                        <th>Trạng thái</th>
                        <th style="text-align:right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int idx = (page - 1) * 10 + 1; }
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="text-muted">@(idx++)</td>
                            <td>
                                <div class="user-chip">
                                    <div class="av">@s.UserId.FirstOrDefault().ToString().ToUpper()</div>
                                    <span class="name">@s.UserId</span>
                                </div>
                            </td>
                            <td class="fw-bold">@s.WorkDate.ToString("dd/MM/yyyy")</td>
                            <td>@(s.Shift ?? "—")</td>
                            <td>
                                @if (s.IsApproved)
                                { <span class="badge-pill success">✅ Đã duyệt</span> }
                                else
                                { <span class="badge-pill warning">⏳ Chờ duyệt</span> }
                            </td>
                            <td style="text-align:right">
                                @if (!s.IsApproved)
                                {
                                    <form asp-action="ApproveSchedule" asp-route-id="@s.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm"
                                                onclick="return confirm('Duyệt lịch này?')">✅ Duyệt</button>
                                    </form>
                                }
                                else
                                { <span class="text-muted" style="font-size:.8rem">Đã xử lý</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <partial name="_Pagination" model='new PaginationModel {
                CurrentPage = page,
                TotalPages  = totalPages,
                Total       = total,
                BaseUrl     = Url.Action("Schedules","Admin")!,
                Search      = search,
                SortBy      = sortBy,
                SortDir     = sortDir,
                Extra1Key   = "filterStatus",
                Extra1Val   = filterStatus
            }' />
        }
    </div>
</div>
