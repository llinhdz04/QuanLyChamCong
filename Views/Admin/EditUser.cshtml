@model ApplicationUser
@{
    ViewData["Title"] = "Sửa thông tin nhân viên";
    Layout = "_AdminLayout";
}

<div style="max-width:620px">
    <div class="mb-3">
        <a asp-action="Users" class="btn btn-ghost btn-sm">← Quay lại danh sách</a>
    </div>

    <div class="card">
        <div class="card-header-bar">
            <h5>✏️ Sửa – @(Model.FullName ?? Model.UserName)</h5>
        </div>
        <div class="card-body">
            <form asp-action="EditUser" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserName" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên đăng nhập</label>
                        <input class="form-control" value="@Model.UserName" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Họ và tên</label>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:.78rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Chức vụ</label>
                        <input asp-for="Position" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Vai trò</label>
                        <select asp-for="Role" class="form-select">
                            <option value="User">Nhân viên</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">
                            Mật khẩu mới
                            <small class="text-muted">(để trống nếu không đổi)</small>
                        </label>
                        <input type="password" name="newPassword" class="form-control"
                               placeholder="Nhập mật khẩu mới..." />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
                    <a asp-action="Users" class="btn btn-ghost">Huỷ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
